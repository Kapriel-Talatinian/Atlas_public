# ==========================================================
# Atlas — minimal VPS config (bot + Telegram monitoring only)
# Copy to `.env` at repo root:  cp deploy/.env.minimal.example .env
# ==========================================================

# =============================================
# REQUIRED — without these the bot won't start
# =============================================

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram ID (send a message to @userinfobot to get it)
TELEGRAM_CHAT_ID=


# =============================================
# POLYMARKET LIVE TRADING (leave empty for paper)
# =============================================
# When all 4 keys below are filled AND POLYMARKET_EXECUTION_MODE=live
# AND POLYMARKET_TRADING_ENABLED=true, the bot places REAL orders.
#
# Get the first three at https://polymarket.com/settings (API Keys)
# The private key is the raw key of the Polygon wallet holding your USDC.
# NEVER commit this file. NEVER share the private key.

POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Public addresses (same value if you use a simple EOA wallet)
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_SIGNER_ADDRESS=


# =============================================
# MODE SWITCH
# =============================================
# `paper` simulates fills locally with starting balance below.
# `live`  places real CLOB orders — requires the keys above
#         AND POLYMARKET_TRADING_ENABLED=true as a safety pin.
POLYMARKET_EXECUTION_MODE=paper

# Set to `true` ONLY when your USDC is approved on the CTF Exchange
# contract 0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E and you are
# ready to place real money orders.
POLYMARKET_TRADING_ENABLED=false


# =============================================
# SIZING & RISK
# =============================================
# Fake balance for paper mode. Irrelevant when live.
POLYMARKET_STARTING_BALANCE_USD=100

# Per-trade ceiling. Polymarket minimum order is $5 — if you run live
# trading, set this to 5 or more.
POLYMARKET_MAX_TRADE_USD=2

# Auto-pause the bot once realized PnL for the day drops below -X$
POLYMARKET_DAILY_LOSS_LIMIT_USD=5

# How many new entries per scanner cycle
POLYMARKET_MAX_NEW_TRADES_PER_CYCLE=2


# =============================================
# SCANNER TUNING (safe defaults)
# =============================================
POLYMARKET_BOT_EVALUATION_SECONDS=5
POLYMARKET_LOOKAHEAD_MINUTES=1440
POLYMARKET_MAX_MARKETS=24
POLYMARKET_REPORT_TIMEZONE=Europe/Paris
