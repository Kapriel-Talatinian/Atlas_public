ASPNETCORE_ENVIRONMENT=Production
PORT=5000
ATLAS_RUNTIME_ROLE=all
# Optional stable identifier. In cloud, prefer an injected replica/instance id.
ATLAS_INSTANCE_ID=atlas-local

# Comma-separated list of allowed origins in production.
# Example: https://<atlas-web>.up.railway.app,https://app.example.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173

# OMS / local persistence fallback
TRADING_DB_PATH=./data/trading/trading.db

# Bot runtime persistence fallback when Postgres is not configured.
EXPERIMENTAL_BOT_STATE_DIR=./data/experimental-bot

# Recommended for multi-replica prod: central runtime store + leader election.
# If set, Atlas uses Postgres for bot state + bot leader lock.
BOT_RUNTIME_DB_CONNECTION_STRING=

# Bot worker cadence / lease timing
BOT_HEARTBEAT_SECONDS=3
BOT_LEASE_SECONDS=15

# Polymarket runtime
# `POLYMARKET_TRADING_ENABLED=true` should only be used once authenticated CLOB routing is wired.
POLYMARKET_TRADING_ENABLED=false
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_BOT_ENABLED=true
POLYMARKET_EXECUTION_MODE=paper
POLYMARKET_MAX_TRADE_USD=1
POLYMARKET_STARTING_BALANCE_USD=100
POLYMARKET_DAILY_LOSS_LIMIT_USD=5
POLYMARKET_LOOKAHEAD_MINUTES=1440
POLYMARKET_MAX_MARKETS=24
POLYMARKET_MAX_NEW_TRADES_PER_CYCLE=2
POLYMARKET_BOT_EVALUATION_SECONDS=12
POLYMARKET_WORKER_HEARTBEAT_SECONDS=4
POLYMARKET_WORKER_LEASE_SECONDS=16
POLYMARKET_REPORT_TIMEZONE=Europe/Paris

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
